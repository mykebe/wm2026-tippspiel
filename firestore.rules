rules_version = '2';
// Replace ADMIN_EMAIL below with the same email you set in firebase-config.js
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "kevin.belortaja+wm@lebensraeume.at";
    }

    // Pool-scoped collections (pools/{poolId}/...). Each deploy hardcodes its
    // own POOL_ID client-side; same logic as the single-pool version, just
    // shifted under the pool path.
    match /pools/{poolId}/users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow update: if isSignedIn() && (
        request.auth.uid == uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /pools/{poolId}/matches/{matchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /pools/{poolId}/bets/{betId} {
      allow read: if isSignedIn() && (
        betId.matches(".*_" + request.auth.uid) ||
        (resource != null && resource.data.uid == request.auth.uid) ||
        isAdmin() ||
        (resource != null &&
         get(/databases/$(database)/documents/pools/$(poolId)/matches/$(resource.data.matchId)).data.kickoff <= request.time)
      );
      allow create: if isAdmin() || (isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && betId == request.resource.data.matchId + "_" + request.auth.uid
                    && get(/databases/$(database)/documents/pools/$(poolId)/matches/$(request.resource.data.matchId)).data.kickoff > request.time
                    && get(/databases/$(database)/documents/pools/$(poolId)/matches/$(request.resource.data.matchId)).data.finished == false
                    && get(/databases/$(database)/documents/pools/$(poolId)/matches/$(request.resource.data.matchId)).data.homeTeam != ""
                    && get(/databases/$(database)/documents/pools/$(poolId)/matches/$(request.resource.data.matchId)).data.awayTeam != "");
      allow update: if isSignedIn() && (
        (resource.data.uid == request.auth.uid
          && get(/databases/$(database)/documents/pools/$(poolId)/matches/$(resource.data.matchId)).data.kickoff > request.time
          && get(/databases/$(database)/documents/pools/$(poolId)/matches/$(resource.data.matchId)).data.finished == false
          && get(/databases/$(database)/documents/pools/$(poolId)/matches/$(resource.data.matchId)).data.homeTeam != ""
          && get(/databases/$(database)/documents/pools/$(poolId)/matches/$(resource.data.matchId)).data.awayTeam != "")
        || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /pools/{poolId}/tournament/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /pools/{poolId}/stats/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Shared inbox across both pools. Each doc carries a `pool` field so admin
    // can tell which pool the message came from. Trust is best-effort; the
    // client just sets it from its own POOL_ID.
    match /feedback/{docId} {
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() < 5000;
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    // Legacy top-level collections — left in place during migration so
    // the one-shot copy script can still read them. Safe to delete after
    // pools/work/ is verified.
    match /users/{uid}            { allow read: if isAdmin(); allow write: if false; }
    match /matches/{matchId}      { allow read: if isAdmin(); allow write: if false; }
    match /bets/{betId}           { allow read: if isAdmin(); allow write: if false; }
    match /tournament/{docId}     { allow read: if isAdmin(); allow write: if false; }
    match /public/{docId}         { allow read: if true;      allow write: if false; }
  }
}
