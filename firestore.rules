rules_version = '2';
// Replace ADMIN_EMAIL below with the same email you set in firebase-config.js
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "kevin.belortaja+wm@lebensraeume.at";
    }

    // user profiles: any signed-in user can read (for the leaderboard);
    // only the user themself can write their profile, except admin can update totalPoints.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (
        request.auth.uid == uid ||
        isAdmin()
      );
      allow delete: if false;
    }

    // matches: any signed-in user can read; only admin writes.
    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // bets: only the owner can read/write their own bet; admin can read & update (for points).
    // Bet writes are blocked once the match has started or finished.
    // Read is allowed by ID pattern so non-existent docs (no resource) can also be checked.
    match /bets/{betId} {
      allow read: if isSignedIn() && (
        betId.matches(".*_" + request.auth.uid) ||
        (resource != null && resource.data.uid == request.auth.uid) ||
        isAdmin()
      );
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && betId == request.resource.data.matchId + "_" + request.auth.uid
                    && get(/databases/$(database)/documents/matches/$(request.resource.data.matchId)).data.kickoff > request.time
                    && get(/databases/$(database)/documents/matches/$(request.resource.data.matchId)).data.finished == false
                    && get(/databases/$(database)/documents/matches/$(request.resource.data.matchId)).data.homeTeam != ""
                    && get(/databases/$(database)/documents/matches/$(request.resource.data.matchId)).data.awayTeam != "";
      allow update: if isSignedIn() && (
        (resource.data.uid == request.auth.uid
          && get(/databases/$(database)/documents/matches/$(resource.data.matchId)).data.kickoff > request.time
          && get(/databases/$(database)/documents/matches/$(resource.data.matchId)).data.finished == false
          && get(/databases/$(database)/documents/matches/$(resource.data.matchId)).data.homeTeam != ""
          && get(/databases/$(database)/documents/matches/$(resource.data.matchId)).data.awayTeam != "")
        || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // tournament config (single document tournament/config) — readable by all signed-in,
    // writable only by admin (used for storing the slot->team-name mapping).
    match /tournament/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // public stats (participantCount) — readable by anyone, including unauthenticated users.
    match /public/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // betting groups — any signed-in user can read (needed to look up invite codes) and create.
    // Only the group owner or admin can update/delete the group document.
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.ownerId || isAdmin()
      );
    }

    // group members — any signed-in user can read; each user can write their own membership.
    match /groups/{groupId}/members/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
  }
}
